# ------------------------------------------------------------------------------
# RAG Assistant — example environment file
#
# Copy this file to `.env` and adjust values:   cp .env.example .env
#
# The canonical reference for every variable is docs/configuration.md; the source
# of truth is backend/app/config.py (each setting has a default + validation).
# The values below are DEVELOPMENT-SAFE defaults. Read the SECURITY WARNING in the
# README before deploying anything to production.
# ------------------------------------------------------------------------------

# --- Core ---------------------------------------------------------------------
# development | test | staging | production
# In production the config validator enforces extra safety checks (see below).
ENVIRONMENT=development

# --- Auth / JWT ---------------------------------------------------------------
# HS256 signing key. Must be 32+ chars and unique per deploy. The app REFUSES to
# start in production with this dev placeholder.
# Generate a real one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=dev_secret_DO_NOT_USE_IN_PRODUCTION_generate_real_secret_with_secrets_module

# Dev-only login shortcut (POST /api/auth/token). MUST stay false outside dev/test.
ALLOW_DEV_LOGIN=false
# Enforce X-Requested-With on mutating requests. Keep true.
REQUIRE_CSRF_HEADER=true

# --- RAG backend selection ----------------------------------------------------
# gemini_hosted | local_openai
DEFAULT_RAG_BACKEND=gemini_hosted
# Keep Gemini-backed stores/routes available. Set false for a local-only deploy.
ENABLE_GEMINI_BACKEND=true
# Must be true before any local_openai store can be created/served.
ENABLE_LOCAL_OPENAI_BACKEND=false

# --- Gemini -------------------------------------------------------------------
# Return deterministic mock responses (no API key needed). Set false to call the
# real Gemini API, in which case GEMINI_API_KEY is required.
GEMINI_MOCK_MODE=true
GEMINI_API_KEY=

# --- Local OpenAI-compatible model (only if DEFAULT_RAG_BACKEND=local_openai) --
# Base URL for an OpenAI-compatible server (Ollama / vLLM / SGLang), e.g.:
#   http://localhost:11434/v1
LOCAL_LLM_BASE_URL=
# Optional bearer token; use EMPTY for servers that ignore auth.
LOCAL_LLM_API_KEY=
# Default local model id, e.g. qwen3:4b
LOCAL_LLM_DEFAULT_MODEL=
# JSON array or comma-separated list of model ids exposed to the frontend picker.
LOCAL_LLM_MODELS=

# --- Database -----------------------------------------------------------------
# SQLAlchemy URL read by the APP. Keep SQLite for small, low-concurrency setups;
# point at PostgreSQL for durability. NOTE: the app does not read DB_PASSWORD —
# embed credentials directly in this URL.
DATABASE_URL=sqlite:///./rag.db

# Used by docker-compose only (Postgres container + the container's DB URL).
# Override both for any non-throwaway Docker deployment.
DB_PASSWORD=changeme_local_only
DOCKER_DATABASE_URL=postgresql+psycopg2://rag:changeme_local_only@db:5432/rag

# --- Redis --------------------------------------------------------------------
# Rate limiting + JWT revocation. Required in production when
# REQUIRE_REDIS_IN_PRODUCTION=true. Empty disables both (dev only).
REDIS_URL=redis://redis:6379/0

# --- HTTP / CORS / limits -----------------------------------------------------
# JSON array or comma-separated list of allowed frontend origins.
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
RATE_LIMIT_PER_MINUTE=120
MAX_UPLOAD_MB=25

# --- Frontend (docker-compose) ------------------------------------------------
# Backend origin the frontend container talks to.
VITE_BACKEND_ORIGIN=http://backend:8000

# ------------------------------------------------------------------------------
# Production invariants (enforced at startup when ENVIRONMENT=production):
#   1. ALLOW_DEV_LOGIN must be false
#   2. DATABASE_URL must not be SQLite
#   3. JWT_SECRET must not equal the dev placeholder above
#   4. DB password must not be blank or a known default
#   5. REDIS_URL must be set when REQUIRE_REDIS_IN_PRODUCTION=true
# See docs/configuration.md for the full variable reference.
# ------------------------------------------------------------------------------
